# ── Copy this file to .env.local and fill in your values ──────────────────
# NEVER commit .env.local to GitHub!

# ── Base Chain RPC ─────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org

# ── Smart Contract Addresses ───────────────────────────────────────────────
NEXT_PUBLIC_DG_TOKEN_ADDRESS=0xf95a71c618048d93a251452d70994cda1b727b07
NEXT_PUBLIC_STAKING_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_NFT_ADDRESS=0x0000000000000000000000000000000000000000

# ── OnchainKit API Key (get free from portal.cdp.coinbase.com) ─────────────
NEXT_PUBLIC_ONCHAINKIT_API_KEY=your_key_here

# ── MiniKit App ID ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_ID=your_app_id_here

# ── Your deployed Vercel URL (change after first deploy) ───────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Treasury Wallet (receives all ETH/USDC payments) ────────────────────────
NEXT_PUBLIC_TREASURY_WALLET=0xfb41eC09b0c8875E2f6D1872bc251a81Bbba65bd
# All ETH payments (mint, shop, upgrade, respawn) go to this wallet on Base

# ── Farcaster Manifest Signing (fill after Step 5 in deploy guide) ─────────
FARCASTER_HEADER=
FARCASTER_PAYLOAD=
FARCASTER_SIGNATURE=

# ── Admin Panel ──────────────────────────────────────────────────────────────
ADMIN_SECRET=CHANGE_THIS_TO_A_STRONG_PASSWORD
ADMIN_WALLETS=0xfb41eC09b0c8875E2f6D1872bc251a81Bbba65bd
# ── Owner/Admin Identity ─────────────────────────────────────────────────────
OWNER_EMAIL=Evillive0007@gmail.com
OWNER_WALLET=0xfb41eC09b0c8875E2f6D1872bc251a81Bbba65bd
